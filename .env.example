# Copie ce fichier en .env et remplis avec tes vraies valeurs

# Neon PostgreSQL — pour Vercel utilise l’URL « Pooled connection » (console.neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Nom du cookie de session (peut rester tel quel)
AUTH_COOKIE_NAME="smile_session"

# AUTH_SECRET (optionnel) : non utilisé par l'auth actuelle (sessions en BDD). À définir si besoin (ex. Vercel).
# Génère avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUTH_SECRET=""
